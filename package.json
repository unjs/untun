{
  "name": "untun",
  "version": "0.1.3",
  "description": "Tunnel your local HTTP(s) server to the world! Powered by Cloudflare Quick Tunnels.",
  "license": "MIT",
  "repository": "unjs/untun",
  "bin": {
    "untun": "./bin/untun.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "obuild",
    "dev": "vitest dev",
    "lint": "oxlint . && oxfmt --check src test",
    "fmt": "oxlint . --fix && oxfmt src test",
    "prepack": "pnpm run build",
    "release": "pnpm test && changelogen --release && npm publish && git push --follow-tags",
    "typecheck": "tsgo --noEmit",
    "test": "pnpm lint && pnpm typecheck &&  vitest run --coverage",
    "untun": "node scripts/untun.ts"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260429.1",
    "@vitest/coverage-v8": "^4.1.5",
    "changelogen": "^0.6.2",
    "eslint-config-unjs": "^0.6.2",
    "obuild": "^0.4.33",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
